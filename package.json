{
  "name": "cipher-lens",
  "private": true,
  "version": "1.0.0",
  "description": "Premium desktop YouTube transcript analyzer with batch summaries, exports, and insight tools.",
  "author": "Cipher",
  "main": "electron/main.cjs",
  "scripts": {
    "start": "node scripts/desktop-launch.mjs",
    "dev": "vite",
    "dev:web": "vite",
    "build": "vite build",
    "lint": "eslint .",
    "preview": "vite preview",
    "package:win": "electron-builder --win nsis --publish never"
  },
  "dependencies": {
    "react": "^19.2.4",
    "react-dom": "^19.2.4",
    "tesseract.js": "^7.0.0",
    "youtube-transcript": "^1.3.0"
  },
  "devDependencies": {
    "@eslint/js": "^9.39.4",
    "@types/node": "^24.12.0",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react": "^6.0.1",
    "electron": "^35.0.0",
    "electron-builder": "^26.8.1",
    "eslint": "^9.39.4",
    "eslint-plugin-react-hooks": "^7.0.1",
    "eslint-plugin-react-refresh": "^0.5.2",
    "globals": "^17.4.0",
    "tsx": "^4.21.0",
    "typescript": "~5.9.3",
    "typescript-eslint": "^8.57.0",
    "vite": "^8.0.1"
  },
  "build": {
    "appId": "com.cipher.generated.cipher.lens",
    "productName": "Cipher Lens",
    "executableName": "Cipher Lens",
    "directories": {
      "output": "release"
    },
    "files": [
      "dist/**/*",
      "electron/**/*",
      "package.json"
    ],
    "win": {
      "icon": "build/icon.ico",
      "signAndEditExecutable": false,
      "target": [
        {
          "target": "nsis",
          "arch": [
            "x64"
          ]
        }
      ]
    },
    "nsis": {
      "artifactName": "${productName}-Setup-${version}.exe",
      "installerIcon": "build/icon.ico",
      "uninstallerIcon": "build/icon.ico",
      "installerHeaderIcon": "build/icon.ico",
      "oneClick": false,
      "createDesktopShortcut": false,
      "allowToChangeInstallationDirectory": true
    }
  }
}
